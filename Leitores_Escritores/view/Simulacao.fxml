                      styleClass="coluna" spacing="6">

                    <Label text="REPORTERS" styleClass="titulo-coluna"/>
                    <Label text="Escritores da Base" styleClass="subtitulo-coluna"/>
                    <Separator styleClass="separador-coluna"/>

                    <ScrollPane fitToWidth="true"
                                styleClass="scroll-cards"
                                VBox.vgrow="ALWAYS">
                        <VBox spacing="6" styleClass="lista-cards">
                            <VBox.margin>
                                <Insets top="4" right="4" bottom="4" left="4"/>
                            </VBox.margin>

                            <!-- Card Reporter 1 -->
                            <VBox styleClass="card-personagem" spacing="5">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <ImageView fx:id="imgEscritor1"
                                               fitWidth="60" fitHeight="75"
                                               preserveRatio="true">
                                        <image>
                                            <Image url="@../img/reporter_ocioso.png"/>
                                        </image>
                                    </ImageView>
                                    <VBox spacing="3">
                                        <Label text="Reporter 1" styleClass="nome-personagem"/>
                                        <Label fx:id="lblEstadoEscritor1"
                                               text="Ocioso"
                                               styleClass="estado-ocioso"/>
                                    </VBox>
                                </HBox>
                                <Label text="obtemDado (ms):" styleClass="label-slider"/>
                                <Slider fx:id="sliderEscObtencao1"
                                        min="200" max="4000" value="2000"
                                        styleClass="slider-custom"/>
                                <Label text="escreveBaseDeDados (ms):" styleClass="label-slider"/>
                                <Slider fx:id="sliderEscEscrita1"
                                        min="200" max="4000" value="2000"
                                        styleClass="slider-custom"/>
                                <Button fx:id="btnPausaEscritor1"
                                        text="Pausar"
                                        styleClass="btn-pausa"
                                        onAction="#handlePausaEscritor1"/>
                            </VBox>

