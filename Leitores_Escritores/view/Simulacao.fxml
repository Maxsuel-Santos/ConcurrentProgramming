                    </ScrollPane>
                </VBox>

                <!-- ===== COLUNA 1: BASE DE DADOS ===== -->
                <VBox GridPane.columnIndex="1" GridPane.rowIndex="0"
                      styleClass="coluna coluna-central"
                      spacing="10" alignment="TOP_CENTER">

                    <Label text="BASE DE DADOS" styleClass="titulo-coluna"/>
                    <Label text="Manchete em Circulacao" styleClass="subtitulo-coluna"/>
                    <Separator styleClass="separador-coluna"/>

                    <VBox alignment="CENTER" spacing="8" VBox.vgrow="ALWAYS">

                        <ImageView fx:id="imgJornal"
                                   fitWidth="200" fitHeight="150"
                                   preserveRatio="true">
                            <image>
                                <Image url="@../img/jornal_fechado.png"/>
                            </image>
                        </ImageView>

                        <VBox styleClass="box-manchete" spacing="6">
                            <Label text="MANCHETE" styleClass="label-manchete-titulo"/>
                            <Separator/>
                            <Label fx:id="lblConteudoBase"
                                   text="Nenhuma materia publicada ainda."
                                   styleClass="label-manchete-conteudo"
                                   wrapText="true"/>
                        </VBox>

                        <VBox styleClass="box-legenda" spacing="5">
                            <Label text="LEGENDA" styleClass="titulo-legenda"/>
                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <Label text="*" styleClass="dot-ativo"/>
                                <Label text="Na regiao critica" styleClass="label-legenda"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <Label text="*" styleClass="dot-aguardando"/>
                                <Label text="Aguardando semaforo" styleClass="label-legenda"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <Label text="*" styleClass="dot-ocioso"/>
                                <Label text="Ocioso" styleClass="label-legenda"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <Label text="*" styleClass="dot-pausado"/>
                                <Label text="Pausado" styleClass="label-legenda"/>
                            </HBox>
                        </VBox>

                        <Button fx:id="btnReset"
                                styleClass="btn-reset"
                                onAction="#handleReset">
                            <graphic>
                                <ImageView fitWidth="200" fitHeight="60"
                                           preserveRatio="true">
                                    <image>
                                        <Image url="@../img/btn_start.png"/>
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>

                    </VBox>
                </VBox>

                <!-- ===== COLUNA 2: REPORTERS (ESCRITORES) ===== -->
