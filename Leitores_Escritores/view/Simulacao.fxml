                                        styleClass="btn-pausa"
                                        onAction="#handlePausaLeitor3"/>
                            </VBox>

                            <!-- Card Editor 4 -->
                            <VBox styleClass="card-personagem" spacing="5">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <ImageView fx:id="imgLeitor4"
                                               fitWidth="60" fitHeight="75"
                                               preserveRatio="true">
                                        <image>
                                            <Image url="@../img/editor_ocioso.png"/>
                                        </image>
                                    </ImageView>
                                    <VBox spacing="3">
                                        <Label text="Editor 4" styleClass="nome-personagem"/>
                                        <Label fx:id="lblEstadoLeitor4"
                                               text="Ocioso"
