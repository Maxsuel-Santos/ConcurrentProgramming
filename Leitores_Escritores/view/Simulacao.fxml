                    <Label text="Leitores da Base" styleClass="subtitulo-coluna"/>
                    <Separator styleClass="separador-coluna"/>

                    <ScrollPane fitToWidth="true"
                                styleClass="scroll-cards"
                                VBox.vgrow="ALWAYS">
                        <VBox spacing="6" styleClass="lista-cards">
                            <VBox.margin>
                                <Insets top="4" right="4" bottom="4" left="4"/>
                            </VBox.margin>

                            <!-- Card Editor 1 -->
                            <VBox styleClass="card-personagem" spacing="5">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <ImageView fx:id="imgLeitor1"
                                               fitWidth="60" fitHeight="75"
                                               preserveRatio="true">
                                        <image>
                                            <Image url="@../img/editor_ocioso.png"/>
                                        </image>
                                    </ImageView>
                                    <VBox spacing="3">
                                        <Label text="Editor 1" styleClass="nome-personagem"/>
                                        <Label fx:id="lblEstadoLeitor1"
                                               text="Ocioso"
                                               styleClass="estado-ocioso"/>
                                    </VBox>
                                </HBox>
                                <Label text="leBaseDeDados (ms):" styleClass="label-slider"/>
                                <Slider fx:id="sliderLeitLeitura1"
                                        min="200" max="4000" value="1500"
                                        styleClass="slider-custom"/>
                                <Label text="utilizaDadoLido (ms):" styleClass="label-slider"/>
                                <Slider fx:id="sliderLeitUtiliza1"
                                        min="200" max="4000" value="1500"
                                        styleClass="slider-custom"/>
                                <Button fx:id="btnPausaLeitor1"
                                        text="Pausar"
                                        styleClass="btn-pausa"
                                        onAction="#handlePausaLeitor1"/>
                            </VBox>

                            <!-- Card Editor 2 -->
