    <!-- ===== RODAPE (LOG) ===== -->
    <bottom>
        <VBox styleClass="rodape" spacing="4">
            <Label text="REGISTRO DE EVENTOS" styleClass="titulo-log"/>
            <TextArea fx:id="areaLog"
                      editable="false"
                      prefHeight="90"
                      styleClass="area-log"/>
        </VBox>
